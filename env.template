# ==============================================================================
# PAPAS APP - Template de variables de entorno
# Copia este archivo a .env y completa los valores
# ==============================================================================

# -----------------------------------------------------------------------------
# INFRAESTRUCTURA
# -----------------------------------------------------------------------------

# Puerto donde Nginx escucha (host)
NGINX_HOST_PORT=80

# Puerto healthcheck de Nginx
NGINX_HEALTH_PORT=8080

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------

# Usuario de PostgreSQL
POSTGRES_USER=papas

# Password de PostgreSQL (cambiar en producción)
POSTGRES_PASSWORD=change_me_please_use_strong_password

# Nombre de la base de datos
POSTGRES_DB=papas_app

# Puerto expuesto de PostgreSQL (opcional, solo para acceso externo)
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# BACKEND NESTJS (Usuario, Login, Perfil, Tareas)
# -----------------------------------------------------------------------------

# Puerto interno del API NestJS
NESTJS_API_PORT=3001

# Secret para JWT (mínimo 32 caracteres)
JWT_SECRET=change_me_to_a_secure_random_string_min_32_chars

# Expiración del JWT (ej: 7d, 1h, 30m)
JWT_EXPIRATION=7d

# -----------------------------------------------------------------------------
# BACKEND FASTAPI (Modelos LLM)
# -----------------------------------------------------------------------------

# Puerto interno del API FastAPI
FASTAPI_PORT=8000

# -----------------------------------------------------------------------------
# FRONTEND (Vue.js)
# -----------------------------------------------------------------------------

# URL del API backend (accesible desde browser)
VITE_API_URL=http://localhost/api

# URL para WebSocket (si es necesario)
VITE_WS_URL=ws://localhost

# -----------------------------------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------------------------------

# Clave para encriptar las credenciales LLM de los usuarios (mínimo 32 caracteres)
# Genera una con: openssl rand -base64 32
LLM_ENCRYPTION_KEY=change_me_to_a_secure_encryption_key_min_32_chars

# CORS origins permitidos (separados por coma)
CORS_ORIGINS=http://localhost,http://localhost:3000

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Nivel de logging: debug, info, warn, error
LOG_LEVEL=info
